PORT=4000

# Supabase (service role)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_FETCH_TIMEOUT_MS=60000

# ShipStation
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=

# Optional (rate limit fail-open)
REDIS_URL=
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_SOCKET_KEEPALIVE_MS=5000

# Optional: canonical public base URL for docs (OpenAPI servers[].url)
# If not set, `/api/v1/openapi.json` infers it from the incoming request host.
PUBLIC_API_BASE_URL=

# Optional
AI_API_DEBUG=false

